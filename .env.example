# Copy this file to .env and fill in your values for local development
# NEVER commit .env to git

# MongoDB connection string
# Get this from MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/perfect-ergonomics?retryWrites=true&w=majority

# Port (optional, defaults to 3002)
PORT=3002
